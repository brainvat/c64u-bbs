#!/usr/bin/env bash
#
# pre-push hook:
#   1. Run the same secrets scan as pre-commit (across all commits being pushed)
#   2. Check that docs/ changes are reflected in docs/toc.json
#

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

found_issues=0

# ============================================================
# PART 1: Secrets scan on the commits about to be pushed
# ============================================================

SECRET_PATTERNS=(
  'password[[:space:]]*[:=][[:space:]]*["\x27]'
  'passwd[[:space:]]*[:=][[:space:]]*["\x27]'
  'secret[[:space:]]*[:=][[:space:]]*["\x27]'
  'api[_-]?key[[:space:]]*[:=][[:space:]]*["\x27]'
  'auth[_-]?token[[:space:]]*[:=][[:space:]]*["\x27]'
  'access[_-]?token[[:space:]]*[:=][[:space:]]*["\x27]'
  'bearer[[:space:]]+[A-Za-z0-9_.+/=-]+'
  'AKIA[0-9A-Z]{16}'
  'ghp_[A-Za-z0-9]{36,}'
  'gho_[A-Za-z0-9]{36,}'
  'ghu_[A-Za-z0-9]{36,}'
  'ghs_[A-Za-z0-9]{36,}'
  'ghr_[A-Za-z0-9]{36,}'
  'sk-[A-Za-z0-9]{20,}'
  'sk-ant-[A-Za-z0-9-]{20,}'
  'xox[bpoas]-[A-Za-z0-9-]{10,}'
  'BEGIN .* PRIVATE KEY'
)

# Read push info from stdin (provided by git)
while read -r local_ref local_sha remote_ref remote_sha; do
  # If remote_sha is all zeros, this is a new branch — scan all commits
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  # Get the diff for the range being pushed
  diff_content=$(git diff "$range" -- 2>/dev/null || git diff --cached 2>/dev/null || true)

  if [ -n "$diff_content" ]; then
    added_lines=$(echo "$diff_content" | grep -E "^\+" | grep -vE "^\+\+\+" || true)

    for pattern in "${SECRET_PATTERNS[@]}"; do
      matches=$(echo "$added_lines" | grep -iE "$pattern" || true)
      if [ -n "$matches" ]; then
        echo -e "${RED}BLOCKED:${NC} Potential secret detected in push ($local_ref):"
        echo "$matches" | head -3 | while read -r line; do
          truncated="${line:0:120}"
          echo -e "  ${YELLOW}${truncated}${NC}"
        done
        found_issues=1
      fi
    done
  fi
done

# ============================================================
# PART 2: Docs consistency check
# ============================================================

# Check if any .md or .html files in docs/ have been modified since last push
# Compare working tree + staged against what the remote has

docs_dir="docs"
toc_json="$docs_dir/toc.json"

if [ -d "$docs_dir" ]; then
  # Get list of .md and .html files currently in docs/ (excluding docs/journal/)
  current_doc_files=$(find "$docs_dir" -maxdepth 3 -type f \( -name "*.md" -o -name "*.html" \) | grep -v "^${docs_dir}/journal/" | sort)

  if [ -n "$current_doc_files" ]; then
    # Read toc.json and extract tracked files
    if [ -f "$toc_json" ]; then
      # Extract file paths from toc.json
      toc_files=$(python3 -c "
import json, sys
try:
    with open('$toc_json') as f:
        data = json.load(f)
    for entry in data.get('files', []):
        print(entry.get('path', ''))
except Exception as e:
    print(f'ERROR: {e}', file=sys.stderr)
    sys.exit(1)
" 2>/dev/null | sort)

      if [ $? -ne 0 ]; then
        echo -e "${RED}BLOCKED:${NC} Failed to parse $toc_json"
        found_issues=1
      else
        # Compare current doc files with toc.json entries
        diff_result=$(diff <(echo "$current_doc_files") <(echo "$toc_files") || true)

        if [ -n "$diff_result" ]; then
          echo -e "${RED}BLOCKED:${NC} docs/ files are out of sync with $toc_json"
          echo -e "${YELLOW}Files in docs/ not tracked in toc.json (or vice versa):${NC}"
          echo "$diff_result" | head -20
          echo ""
          echo -e "Run ${GREEN}python3 scripts/update_docs_toc.py${NC} to re-index,"
          echo -e "or use the ${GREEN}/update-docs${NC} Claude Code skill to fix this automatically."
          found_issues=1
        fi

        # Also check that modification times are consistent
        # (toc.json should be newer than any doc file it tracks)
        if [ -f "$toc_json" ]; then
          toc_mtime=$(stat -f %m "$toc_json" 2>/dev/null || stat -c %Y "$toc_json" 2>/dev/null || echo 0)
          for doc_file in $current_doc_files; do
            file_mtime=$(stat -f %m "$doc_file" 2>/dev/null || stat -c %Y "$doc_file" 2>/dev/null || echo 0)
            if [ "$file_mtime" -gt "$toc_mtime" ]; then
              echo -e "${RED}BLOCKED:${NC} ${YELLOW}$doc_file${NC} is newer than $toc_json"
              echo -e "Run ${GREEN}python3 scripts/update_docs_toc.py${NC} to re-index."
              found_issues=1
              break
            fi
          done
        fi
      fi
    else
      echo -e "${RED}BLOCKED:${NC} $toc_json does not exist but docs/ contains files."
      echo -e "Run ${GREEN}python3 scripts/update_docs_toc.py${NC} to create it."
      found_issues=1
    fi
  fi
fi

# ============================================================
# Final verdict
# ============================================================

if [ "$found_issues" -ne 0 ]; then
  echo ""
  echo -e "${RED}Push rejected.${NC} Fix the issues above before pushing."
  echo "This is a PUBLIC repository — all pushed content is visible to everyone."
  exit 1
fi

echo -e "${GREEN}Pre-push checks passed.${NC}"
exit 0
